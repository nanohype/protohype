# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Okta
OKTA_DOMAIN=https://acmecorp.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-api-token

# Notion OAuth App
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=https://acmeask.acmecorp.internal/oauth/notion/callback

# Confluence OAuth App (Atlassian)
CONFLUENCE_CLIENT_ID=your-atlassian-client-id
CONFLUENCE_CLIENT_SECRET=your-atlassian-client-secret
CONFLUENCE_REDIRECT_URI=https://acmeask.acmecorp.internal/oauth/confluence/callback
CONFLUENCE_BASE_URL=https://acmecorp.atlassian.net/wiki

# Google OAuth App
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://acmeask.acmecorp.internal/oauth/google/callback

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...  # Optional fallback
COHERE_API_KEY=...             # Optional reranking

# AWS
AWS_REGION=us-east-1
SECRETS_MANAGER_PREFIX=acmeask
CLOUDWATCH_LOG_GROUP=/acmeask/audit

# App
PORT=3000
NODE_ENV=production
STALE_THRESHOLD_DAYS=90
RETRIEVAL_TIMEOUT_MS=1500
MAX_QUERIES_PER_HOUR=20
TOP_K_PER_CONNECTOR=5
TOP_K_FINAL=8
BASE_URL=https://acmeask.acmecorp.internal
