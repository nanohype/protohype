{
  "name": "mcp-switchboard",
  "version": "0.1.0",
  "description": "Self-hosted MCP gateway — HubSpot, Google Drive, Calendar, Analytics, CSE, and Stripe as remote MCP servers behind AWS API Gateway + Lambda",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch src/local.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/lambda.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/lambda.js --external:@aws-sdk/*",
    "deploy": "npm install && cd infra && npm install && npx cdk deploy",
    "infra:deploy": "cd infra && npx cdk deploy",
    "infra:synth": "cd infra && npx cdk synth"
  },
  "dependencies": {
    "@hubspot/api-client": "^13.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "dotenv": "^17.4.2",
    "stripe": "^22.0.1",
    "zod": "^4.3.6",
    "@aws-sdk/client-secrets-manager": "^3.1030.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/aws-lambda": "^8.10.161",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "esbuild": "^0.28.0"
  }
}
