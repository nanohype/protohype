{
  "name": "mcp-switchboard",
  "version": "0.1.0",
  "description": "Self-hosted MCP gateway — HubSpot, Google Drive, Calendar, Analytics, CSE, and Stripe as remote MCP servers behind AWS API Gateway + Lambda",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch src/local.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/lambda.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/lambda.js --external:@aws-sdk/*",
    "deploy": "npm install && cd infra && npm install && npx cdk deploy",
    "infra:deploy": "cd infra && npx cdk deploy",
    "infra:synth": "cd infra && npx cdk synth"
  },
  "dependencies": {
    "@hubspot/api-client": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "express": "^5.0.0",
    "googleapis": "^144.0.0",
    "dotenv": "^16.4.0",
    "stripe": "^17.0.0",
    "zod": "^3.24.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/aws-lambda": "^8.10.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0",
    "esbuild": "^0.24.0"
  }
}
