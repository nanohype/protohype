# Local dev only — in production, credentials come from AWS Secrets Manager.
# Do NOT commit real credentials. Copy to .env and fill in values.

# ─── Service: HubSpot ────────────────────────────────────────────────────────
HUBSPOT_API_KEY=pat-na1-xxxxxxxxxxxxxxxxxxxx

# ─── Service: Google (Drive, Calendar, Analytics) ─────────────────────────────
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account.json

# For Calendar: the email to impersonate via domain-wide delegation
GOOGLE_IMPERSONATE_EMAIL=you@yourdomain.com

# For Analytics: GA4 property ID (numbers only, no "properties/" prefix)
GA4_PROPERTY_ID=123456789

# ─── Service: Google Custom Search ───────────────────────────────────────────
GCSE_API_KEY=AIzaSy...
GCSE_ENGINE_ID=abc123...

# ─── Service: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ─── Infrastructure ──────────────────────────────────────────────────────────
# Prefix for Secrets Manager secret names (default: mcp-proxy)
SECRET_PREFIX=mcp-proxy

# AWS region for Secrets Manager (default: us-east-1)
AWS_REGION=us-east-1

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Local server port
PORT=3000
