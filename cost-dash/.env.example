# === cost-dash configuration ===

# ── Storage ──
# In production: set PERF_BUCKET to use S3.
# In development: leave unset to use a local .perf.json file.
# PERF_BUCKET=my-cost-dash-bucket
# PERF_KEY=perf.json

# Local file path (dev only, ignored when PERF_BUCKET is set)
# PERF_FILE=./.perf.json

# ── Budget ──
# Daily budget alert threshold in USD (default: $10)
DAILY_BUDGET_USD=10

# Per-session budget alert threshold in USD (default: $1)
PER_SESSION_BUDGET_USD=1

# ── Optional ──
# Anthropic Admin API key for supplemental usage data
# Different from the standard API key — requires admin scope
# If unset, dashboard runs on perf store data only
# ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# Allow /api/seed in production (default: false — seed disabled in prod)
# ALLOW_SEED=false

# Node environment
NODE_ENV=development

# Port (Next.js default: 3000)
PORT=3000
