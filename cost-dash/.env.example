# === cost-dash configuration ===

# Path to the perf log (defaults to .perf.json in cwd)
# On Fly.io, mount a volume and set this to the mounted path
PERF_FILE=/data/.perf.json

# Daily budget alert threshold in USD (default: $10)
DAILY_BUDGET_USD=10

# Per-session budget alert threshold in USD (default: $1)
PER_SESSION_BUDGET_USD=1

# Optional: Anthropic Admin API key for supplemental usage data
# Different from the standard API key — requires admin scope
# If unset, dashboard runs on local .perf.json data only
# ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# Allow /api/seed in production (default: false — seed disabled in prod)
# ALLOW_SEED=false

# Node environment
NODE_ENV=development

# Port (Next.js default: 3000)
PORT=3000
