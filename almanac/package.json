{
  "name": "almanac",
  "private": true,
  "workspaces": [
    "packages/*",
    "infra"
  ],
  "scripts": {
    "build": "tsc --build packages/*/tsconfig.json infra/tsconfig.json",
    "test": "jest --projects packages/*/jest.config.js",
    "lint": "eslint 'packages/*/src/**/*.ts' 'infra/lib/**/*.ts'",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
