# MCP Gateway — Dashboard environment variables
# Copy to .env.local for local development

# API Gateway base URL (from CDK output: McpGateway-ApiEndpoint)
NEXT_PUBLIC_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-west-2.amazonaws.com

# AWS region (default: us-west-2)
NEXT_PUBLIC_AWS_REGION=us-west-2

# NOTE: The API token is NOT a build-time env var. It is entered via the
# dashboard login prompt and stored in the browser's localStorage.
# Get your token:
#   aws secretsmanager get-secret-value \
#     --secret-id /mcp-gateway/gateway-bearer-token \
#     --query SecretString --output text
