{
  "name": "mcp-gateway",
  "version": "0.1.0",
  "description": "Unified API Gateway + Lambda CDK stack — MCP Switchboard, MCP Memory Server, Cost Dashboard",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "smoke": "jest --config jest.smoke.config.js",
    "cdk": "cdk",
    "deploy": "cdk deploy --require-approval never",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "lint": "eslint 'lib/**/*.ts' 'bin/**/*.ts' 'lambda/**/*.ts'"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30",
    "@types/node": "^22",
    "typescript-eslint": "^8.58.1",
    "aws-cdk": "^2.1118.0",
    "esbuild": "^0.28.0",
    "eslint": "^10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-lambda": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-secrets-manager": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "aws-cdk-lib": "^2.248.0",
    "constructs": "^10.6.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/smoke/"],
    "transform": {"^.+\\.tsx?$": "ts-jest"}
  }
}
