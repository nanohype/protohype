{
  "app": "npx ts-node --prefer-ts-exts bin/mcp-gateway.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md","cdk*.json","**/*.d.ts","**/*.js","tsconfig.json","package*.json",".npmignore","yarn.lock","node_modules","dist","test"]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/aws-cloudwatch-actions:changeLambdaPermissionLogicalIdForLambdaAction": true,
    "@aws-cdk/aws-codepipeline-actions:useNewDefaultBranchForCodeCommitSource": false,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "@aws-cdk/aws-events:eventsTargetQueueSameAccount": false,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/aws-iam:standardizedServicePrincipals": true,
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/aws-rds:lowercaseDbIdentifier": true,
    "@aws-cdk/aws-redshift:useLegacyS3ImportRole": false,
    "@aws-cdk/aws-route53-patching:fixReusableDelegationSetInstallMethod": false,
    "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"]
  }
}
