# ─── Runtime ───
NODE_ENV=development
AWS_REGION=us-east-1
LOG_LEVEL=info

# ─── Bedrock ───
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
BEDROCK_MAX_TOKENS=2000
BEDROCK_TEMPERATURE=0.4

# ─── Secrets Manager ───
# Auth config — JSON: { "cosUserId": "...", "backupApproverIds": ["..."] }
APPROVERS_SECRET_ID=dispatch/approvers

# ─── WorkOS ───
# JWT validation — issuer and client ID (used as audience)
WORKOS_ISSUER=https://api.workos.com
WORKOS_CLIENT_ID=client_01ABC...
# WorkOS Directory Sync — JSON: { "apiKey": "...", "directoryId": "..." }
WORKOS_DIRECTORY_SECRET_ID=dispatch/workos-directory

# ─── Database ───
# Full connection string loaded from Secrets Manager in deployed env.
# For local dev:
DATABASE_URL=postgres://dispatch_app:dispatch_app@localhost:5432/dispatch

# ─── S3 ───
VOICE_BASELINE_BUCKET=dispatch-voice-baseline-dev
RAW_AGGREGATIONS_BUCKET=dispatch-raw-aggregations-dev

# ─── Slack (for alerts + draft notifications) ───
SLACK_REVIEW_CHANNEL_ID=C0000000000

# ─── Aggregator service secrets (Secrets Manager) ───
# Each is a JSON secret with the shape documented below.
#
# GITHUB_SECRET_ID → { token: string, repos: [{ owner: string, repo: string }, ...] }
GITHUB_SECRET_ID=dispatch/github
#
# LINEAR_SECRET_ID → { apiKey: string, askLabel?: string }
LINEAR_SECRET_ID=dispatch/linear
#
# SLACK_SECRET_ID → { botToken, announcementsChannelId, teamChannelId, hrBotUserIds: [] }
# Same secret used by the API's SlackConfirmer (only the botToken field is read there).
SLACK_SECRET_ID=dispatch/slack
#
# NOTION_SECRET_ID → { apiKey, databaseId }  (databaseId = all-hands database)
NOTION_SECRET_ID=dispatch/notion

# ─── API server ───
PORT=3001
# Comma-separated list of allowed web origins (CORS allow-list).
# Locally: http://localhost:3000  Staging/prod: https://dispatch[-staging].internal.company.com
WEB_ORIGIN=http://localhost:3000

# ─── OpenTelemetry ───
# OTLP/HTTP endpoint of the ADOT Collector sidecar. In dev, point at a local
# collector docker container (or set OTEL_SDK_DISABLED=true to skip OTel entirely).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=dispatch-pipeline
# Set to "true" in tests/local-without-collector to disable the SDK + Pino transport.
# OTEL_SDK_DISABLED=true

# Grafana Cloud credentials live in Secrets Manager — the collector sidecar reads
# them, not the app. Shape: { instanceId, apiToken, otlpEndpoint, authHeader }
# authHeader is pre-computed: "Basic " + base64("instanceId:apiToken")
# (logs go to CloudWatch, not Loki — Grafana adds CloudWatch as a data source)
GRAFANA_CLOUD_SECRET_ID=dispatch/grafana-cloud
