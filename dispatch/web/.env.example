# ─── WorkOS AuthKit ───
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_01ABC...
WORKOS_COOKIE_PASSWORD=generate-a-random-string-of-at-least-32-chars
WORKOS_REDIRECT_URI=http://localhost:3000/callback

# ─── Dispatch API ───
# Internal ALB DNS for the dispatch Fastify API service (same VPC).
API_BASE_URL=http://dispatch-api.dispatch-staging.internal:3001

# ─── OpenTelemetry ───
# Collector sidecar endpoint (server-side). Browser SDK posts to /api/otel/v1/traces
# which proxies here.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=dispatch-web
# OTEL_SDK_DISABLED=true
