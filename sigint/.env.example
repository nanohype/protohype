# ─── Provider Selection ───
LLM_PROVIDER=bedrock              # bedrock (default) | anthropic | openai
EMBEDDING_PROVIDER=bedrock         # bedrock (default) | openai

# ─── AWS Bedrock (uses credential chain — no keys needed) ───
AWS_REGION=us-east-1
BEDROCK_LLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ─── Direct API keys (only if using anthropic/openai providers) ───
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Embeddings ───
EMBEDDING_DIMENSIONS=1024          # 1024 for Titan v2, 1536 for OpenAI

# ─── Vector Store ───
VECTOR_PROVIDER=memory             # memory (data lost on restart)

# ─── Crawler ───
CRAWL_INTERVAL_MINUTES=60
CRAWL_TIMEOUT_MS=30000
USER_AGENT=sigint/0.1.0

# ─── Slack (optional — CLI works without it) ───
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=
# SLACK_APP_TOKEN=xapp-...
SLACK_ALERT_CHANNEL="#competitive-intel"

# ─── Analysis ───
SIGNIFICANCE_THRESHOLD=0.3        # 0–1, semantic change required to trigger alert

# ─── Server ───
PORT=3000
NODE_ENV=development
LOG_LEVEL=info                     # debug | info | warn | error
