# ── Redis Store ──────────────────────────────────────────────────────

# Full Redis connection URL (takes precedence over host/port)
# REDIS_URL=redis://localhost:6379

# Redis host (used when REDIS_URL is not set)
# REDIS_HOST=127.0.0.1

# Redis port (used when REDIS_URL is not set)
# REDIS_PORT=6379

# Redis password (used when REDIS_URL is not set)
# REDIS_PASSWORD=
