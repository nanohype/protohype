# ── Training Provider ─────────────────────────────────────────────────
# API key for the fine-tuning provider. The OpenAI SDK reads this
# automatically when constructing its client.
OPENAI_API_KEY=sk-your-openai-api-key

# ── Dataset ──────────────────────────────────────────────────────────
# Path to raw training data (JSONL with system/user/assistant messages)
DATA_INPUT_PATH=./data/examples/raw.jsonl

# Output directory for prepared dataset splits
DATA_OUTPUT_DIR=./data/prepared

# Train/validation/test split ratios (must sum to 1.0)
SPLIT_TRAIN_RATIO=0.8
SPLIT_VAL_RATIO=0.1
SPLIT_TEST_RATIO=0.1

# ── Training ─────────────────────────────────────────────────────────
# Base model to fine-tune
BASE_MODEL=gpt-4o-mini-2024-07-18

# Number of training epochs (leave empty for provider auto)
# TRAINING_EPOCHS=3

# Learning rate multiplier (leave empty for provider auto)
# LEARNING_RATE_MULTIPLIER=1.8

# Batch size (leave empty for provider auto)
# BATCH_SIZE=1

# Training job suffix (appended to fine-tuned model name)
TRAINING_SUFFIX=palisade-fine-tune

# ── Eval ─────────────────────────────────────────────────────────────
# Fine-tuned model ID for evaluation (set after training completes)
# FINE_TUNED_MODEL=ft:gpt-4o-mini-2024-07-18:org::id

# Number of test examples to evaluate
EVAL_SAMPLE_SIZE=20

# ── Application ──────────────────────────────────────────────────────
LOG_LEVEL=info
