{
  "name": "palisade-llm-gateway",
  "version": "0.1.0",
  "description": "LLM gateway for palisade",
  "type": "module",
  "main": "dist/gateway/index.js",
  "types": "dist/gateway/index.d.ts",
  "exports": {
    ".": "./dist/gateway/index.js",
    "./providers": "./dist/gateway/providers/index.js",
    "./routing": "./dist/gateway/routing/index.js",
    "./caching": "./dist/gateway/caching/index.js",
    "./cost": "./dist/gateway/cost/tracker.js",
    "./tokens": "./dist/gateway/tokens/counter.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/gateway/index.ts",
    "start": "node dist/gateway/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@opentelemetry/api": "^1.9.0",
    "groq-sdk": "^0.15.0",
    "js-tiktoken": "^1.0.0",
    "openai": "^4.85.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
