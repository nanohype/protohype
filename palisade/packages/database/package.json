{
  "name": "palisade-database",
  "version": "0.1.0",
  "description": "Drizzle postgres for palisade",
  "type": "module",
  "main": "dist/db/index.js",
  "types": "dist/db/index.d.ts",
  "exports": {
    ".": "./dist/db/index.js",
    "./schema": "./dist/db/schema.js",
    "./drivers": "./dist/db/drivers/index.js",
    "./migrate": "./dist/db/migrate.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/db/index.ts",
    "start": "node dist/db/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0",
    "better-sqlite3": "^11.0.0",
    "@libsql/client": "^0.15.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
