{
  "name": "palisade-guardrails",
  "version": "0.1.0",
  "description": "Safety filters for palisade",
  "type": "module",
  "main": "dist/guardrails/index.js",
  "types": "dist/guardrails/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/guardrails/index.d.ts",
      "import": "./dist/guardrails/index.js"
    },
    "./filters": {
      "types": "./dist/guardrails/filters/index.d.ts",
      "import": "./dist/guardrails/filters/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
