{
  "name": "palisade-llm-providers",
  "version": "0.1.0",
  "description": "LLM providers for palisade",
  "type": "module",
  "main": "dist/llm-providers/index.js",
  "types": "dist/llm-providers/index.d.ts",
  "exports": {
    ".": "./dist/llm-providers/index.js",
    "./providers": "./dist/llm-providers/providers/index.js",
    "./adapters": "./dist/llm-providers/adapters/gateway.js",
    "./tokens": "./dist/llm-providers/tokens/counter.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/llm-providers/index.ts",
    "start": "node dist/llm-providers/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@google-cloud/vertexai": "^1.9.0",
    "@huggingface/inference": "^3.6.0",
    "@opentelemetry/api": "^1.9.0",
    "groq-sdk": "^0.15.0",
    "js-tiktoken": "^1.0.18",
    "openai": "^4.85.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
