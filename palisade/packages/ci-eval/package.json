{
  "name": "palisade-ci-eval",
  "version": "0.1.0",
  "description": "Detection regression gate",
  "type": "module",
  "scripts": {
    "eval": "tsx src/ci-eval/index.ts run",
    "eval:ci": "tsx src/ci-eval/index.ts run --json",
    "eval:compare": "tsx src/ci-eval/index.ts compare",
    "eval:update-baseline": "tsx src/ci-eval/index.ts update-baseline",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "openai": "^4.85.0",
    "js-yaml": "^4.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
