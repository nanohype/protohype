{
  "name": "palisade",
  "version": "0.1.0",
  "description": "Prompt-injection detection gateway and honeypot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "test:integration:docker": "docker run -d --name palisade-ddb-local -p 8000:8000 amazon/dynamodb-local >/dev/null && DDB_LOCAL_ENDPOINT=http://localhost:8000 vitest run src/**/*.integration.test.ts; status=$?; docker rm -f palisade-ddb-local >/dev/null; exit $status",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "ci:grep-gate": "bash scripts/ci/grep-gate.sh",
    "ci:grep-error-leak": "bash scripts/ci/grep-error-leak.sh",
    "ci:grep-vi-mock": "bash scripts/ci/grep-vi-mock.sh",
    "ci:all": "npm run ci:grep-gate && npm run ci:grep-error-leak && npm run ci:grep-vi-mock && npm run check",
    "eval:run": "tsx scripts/eval/run.ts",
    "eval:baseline": "tsx scripts/eval/update-baseline.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "jose": "^6.0.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "pino": "^9.5.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-cloudwatch": "^3.750.0",
    "@smithy/node-http-handler": "^4.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.56.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.56.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
