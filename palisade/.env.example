# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ── AWS ──────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
# CDK_DEFAULT_REGION=us-west-2

DDB_TABLE_AUDIT=palisade-audit
DDB_TABLE_LABEL_QUEUE=palisade-label-queue

# SQS + S3 for attack-log fan-out (leave unset for in-memory dev mode)
# SQS_ATTACK_LOG_URL=
# SQS_ATTACK_LOG_DLQ_URL=
# S3_ARCHIVE_BUCKET=

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Postgres (pgvector) ──────────────────────────────────────────────
PG_URL=postgres://palisade:palisade@localhost:5432/palisade

# ── Bedrock ──────────────────────────────────────────────────────────
BEDROCK_REGION=us-west-2
BEDROCK_CLASSIFIER_MODEL_ID=anthropic.claude-haiku-4-5-20251001
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Detection thresholds ─────────────────────────────────────────────
HEURISTICS_BASE64_MIN_BYTES=256
CLASSIFIER_BLOCK_THRESHOLD=0.85
CLASSIFIER_ALLOW_THRESHOLD=0.25
CORPUS_MATCH_THRESHOLD=0.88
CORPUS_MATCH_TOP_K=5

HEURISTICS_TIMEOUT_MS=50
CLASSIFIER_TIMEOUT_MS=2500
CORPUS_MATCH_TIMEOUT_MS=1500

# ── Rate limit ───────────────────────────────────────────────────────
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_ESCALATION_SECONDS=900

# ── OTel ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=palisade
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Upstreams ────────────────────────────────────────────────────────
UPSTREAM_OPENAI_URL=https://api.openai.com
UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com
UPSTREAM_BEDROCK_URL=https://bedrock-runtime.us-west-2.amazonaws.com

# ── Dev ──────────────────────────────────────────────────────────────
# Set to true to bypass AWS/Redis/PG and use in-process fakes
PALISADE_USE_FAKES=false
