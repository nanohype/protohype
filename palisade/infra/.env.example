# ── AWS CDK ───────────────────────────────────────────────────────────
# CDK uses the AWS SDK credential chain (env vars, ~/.aws/credentials, IAM role).
# These are read by CDK at synth/deploy time.

# Optional: AWS account ID (CDK reads CDK_DEFAULT_ACCOUNT if set)
# CDK_DEFAULT_ACCOUNT=123456789012

# Optional: AWS region override (CDK reads CDK_DEFAULT_REGION if set)
# CDK_DEFAULT_REGION=us-east-1
