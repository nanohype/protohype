# Marshal — environment configuration template.
# Copy to `.env` for local dev; production values come from AWS Secrets Manager via ECS task definition.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── Slack (socket mode) ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-replace-with-bot-token
SLACK_SIGNING_SECRET=replace-with-signing-secret
SLACK_APP_TOKEN=xapp-replace-with-app-level-token

# ── Grafana OnCall (webhook source + escalation chain API) ───────────────────
GRAFANA_ONCALL_TOKEN=replace-with-grafana-oncall-api-token
GRAFANA_ONCALL_BASE_URL=https://oncall-prod-us-central-0.grafana.net

# ── Grafana Cloud (read-only Mimir/Loki/Tempo for context snapshot) ──────────
GRAFANA_CLOUD_TOKEN=replace-with-grafana-cloud-api-token
GRAFANA_CLOUD_ORG_ID=replace-with-org-id
GRAFANA_CLOUD_BASE_URL=https://prometheus-prod-01-prod-us-east-0.grafana.net

# ── Statuspage.io (customer-facing status; approval-gated) ───────────────────
STATUSPAGE_API_KEY=replace-with-statuspage-api-key
STATUSPAGE_PAGE_ID=replace-with-page-id

# ── Linear (postmortem draft destination) ────────────────────────────────────
LINEAR_API_KEY=replace-with-linear-api-key
LINEAR_PROJECT_ID=replace-with-linear-project-id
LINEAR_TEAM_ID=replace-with-linear-team-id

# ── WorkOS Directory Sync (responder resolution by group) ────────────────────
WORKOS_API_KEY=sk_live_replace-with-workos-api-key
# Optional: JSON map from grafana team_id → WorkOS directory_group_id. Example:
# WORKOS_TEAM_GROUP_MAP={"team-platform":"directory_group_01...","team-data":"directory_group_01..."}

# ── GitHub (CODEOWNERS + recent commits for postmortem deploy timeline) ──────
GITHUB_TOKEN=replace-with-github-pat-or-app-token
GITHUB_ORG_SLUG=your-org
# Comma-separated list of repos the postmortem should query for recent deploys.
GITHUB_REPO_NAMES=svc-api,svc-worker,svc-frontend

# ── DynamoDB tables (set by CDK at deploy time) ──────────────────────────────
# Staging values shown for local dev; production swaps the env segment.
INCIDENTS_TABLE_NAME=marshal-staging-incidents
AUDIT_TABLE_NAME=marshal-staging-audit

# ── SQS queues (set by CDK at deploy time) ───────────────────────────────────
INCIDENT_EVENTS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/marshal-staging-incident-events.fifo
NUDGE_EVENTS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/marshal-staging-nudge-events
SLA_CHECK_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/marshal-staging-sla-check-events

# ── EventBridge Scheduler (set by CDK) ───────────────────────────────────────
SCHEDULER_ROLE_ARN=arn:aws:iam::000000000000:role/MarshalStaging-SchedulerRole
# Env-scoped scheduler group so staging + production nudge rules don't collide.
# Staging: marshal-staging | Production: marshal-production
SCHEDULER_GROUP_NAME=marshal-staging

# ── HMAC webhook secret ARN (set by CDK) ─────────────────────────────────────
GRAFANA_ONCALL_HMAC_SECRET_ARN=arn:aws:secretsmanager:us-west-2:000000000000:secret:marshal/staging/grafana/oncall-webhook-hmac

# ── Logical environment (set by CDK) ─────────────────────────────────────────
# One of: staging | production. Drives OTel deployment.environment + log labels.
DEPLOYMENT_ENV=staging

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
