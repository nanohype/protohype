# chorus — environment variables
# (requires Node 24+; see package.json `engines`)
#
# Every variable below is read at first use. If a required variable is
# unset, the process throws with a clear error rather than falling
# back to a placeholder. Copy this file to `.env` and fill in values.

# ─── Database ──────────────────────────────────────────────────────
# Postgres connection string. The database must have the `vector` and
# `uuid-ossp` extensions available (see migrations/001_init.sql).
DATABASE_URL=postgres://chorusapp:CHANGEME@localhost:5432/chorus

# ─── WorkOS AuthKit (required for JWT verification in auth.ts) ─────
# WORKOS_CLIENT_ID is required; auth.ts throws on startup if it's
# unset. WORKOS_ISSUER defaults to https://api.workos.com — only set
# it if you have a custom AuthKit auth domain.
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
# WORKOS_ISSUER=https://api.workos.com

# ─── WorkOS Directory Sync (required for the digest job) ───────────
# The digest job enumerates PMs from a synced directory group. Both
# values come from the WorkOS dashboard.
# WORKOS_DIRECTORY_ID=directory_01XXXXXXXXXXXXXXXXXXXXXXXX
# WORKOS_PM_GROUP_ID=directory_group_01XXXXXXXXXXXXXXXXXXXXXXXX

# ─── AWS ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# SQS DLQ URL. If unset, dead-letter messages are logged to stderr
# instead of being enqueued.
# DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/chorus-dlq

# SQS audit queue URL. When set, every AuditLogEntry is enqueued to
# this queue (bootstrapAuditWriter switches to the queueing writer)
# and drained by the audit-consumer service. When unset, writes go
# directly to the audit_log table on the request path.
# AUDIT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/chorus-audit

# ─── Bedrock models ────────────────────────────────────────────────
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
TITLE_GEN_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# ─── API hardening ─────────────────────────────────────────────────
# Comma-separated list of origins the /api/proposals routes accept on
# CORS preflight. An empty / unset value rejects every cross-origin
# request — same-origin (no Origin header) always succeeds so the ALB
# health probe keeps working.
CORS_ALLOWED_ORIGINS=https://chorus.acme.com

# Per-user token-bucket budget on the three write routes
# (approve / reject / defer), shared across all three. Default 30/min.
# API_WRITE_RATE_PER_MIN=30

# ─── Linear (backlog management) ───────────────────────────────────
# Linear team id — required when a PM approves a NEW proposal and
# chorus creates a new issue on their behalf. The mirror job pulls
# all issues from this team into backlog_entries via GraphQL.
LINEAR_TEAM_ID=team_01XXXXXXXXXXXXXXXXXXXXXXXX

# Linear mirror cadence (seconds). Default 1 hour.
# LINEAR_MIRROR_INTERVAL_SECONDS=3600

# ─── Slack Events ingestion ────────────────────────────────────────
# Comma-separated `channelId=squadId` mapping — messages landing in
# these channels are fed into the matching pipeline and their ACLs
# are scoped to the mapped squad.
#   SLACK_FEEDBACK_CHANNELS=C0ABCDE=growth,C0XYZ12=billing

# ─── Matching ──────────────────────────────────────────────────────
# Cosine-similarity threshold for LINK proposals. A topCandidate with
# similarityScore >= this becomes a LINK proposal; otherwise the
# matcher checks the duplicate guard (hard-coded at 0.85) and falls
# through to NEW with a draft title.
MATCH_THRESHOLD=0.78

# ─── Secrets Manager IDs ───────────────────────────────────────────
# These are secret *names* (not values); the actual secrets are
# fetched via SecretsManager at use time. Names are hard-coded in
# src/lib/directory.ts and src/lib/slack.ts — documented here for ops:
#   chorus/workos/api-key         (WorkOS API key for Directory Sync)
#   chorus/slack/bot-token        (Slack bot OAuth token — outbound)
#   chorus/slack/signing-secret   (Slack app signing secret for
#                                  Events API request verification)
#   chorus/linear/api-key         (Linear personal API key)
#   chorus/ingest/api-key         (Shared Bearer key for /api/ingest
#                                  webhook callers)
#   chorus/grafana-cloud/otlp     (Full `Basic <base64(instance:token)>`
#                                  Authorization header for the ADOT
#                                  sidecar's OTLP HTTP exporter)

# ─── OpenTelemetry ─────────────────────────────────────────────────
# Local runs typically don't have a collector, so SDK stays off.
# `make otel-local` starts one; unset this var (or set to false)
# and set OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 to stream
# to it.
OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=chorus-dev
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
# DEPLOYMENT_ENV=dev
