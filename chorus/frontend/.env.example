# chorus-frontend — environment variables. Copy to .env.local.

# Where the chorus API is reachable (server-side only — never the browser).
CHORUS_API_BASE_URL=http://localhost:3000

# WorkOS AuthKit. The cookie password must be at least 32 characters
# (`openssl rand -base64 32` is fine). The redirect URI must match the
# one configured in the WorkOS dashboard.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3001/callback

# Local-dev escape hatch: when NODE_ENV !== 'production', the frontend
# uses this string as the bearer token instead of going through WorkOS.
# CHORUS_DEV_BEARER=
