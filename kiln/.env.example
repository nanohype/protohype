# Kiln environment variables — copy to .env and populate before running locally.
# Every var here is validated at startup via zod in src/config.ts; missing or
# malformed values fail fast rather than surfacing as runtime errors.

# ── Runtime ───────────────────────────────────────────────────────────────────
KILN_ENV=dev                               # dev | staging | prod
KILN_LOG_LEVEL=info                        # debug | info | warn | error
KILN_REGION=us-west-2

# ── AWS (for CDK deploy + local dev against real AWS) ────────────────────────
# REQUIRED: replace the account id with your kiln sub-account before deploy.
AWS_REGION=us-west-2
CDK_DEFAULT_ACCOUNT=000000000000
CDK_DEFAULT_REGION=us-west-2

# ── WorkOS AuthKit (API Gateway JWT authorizer + local dev verification) ─────
# REQUIRED: replace with your actual WorkOS Client ID + issuer before deploy.
# The AuthKit issuer is https://api.workos.com for hosted AuthKit, or the
# domain of your own AuthKit project. Get the clientId from the WorkOS dash.
# JWKS URL defaults to ${issuer}/sso/jwks/${clientId} unless overridden.
KILN_WORKOS_ISSUER=https://api.workos.com
KILN_WORKOS_CLIENT_ID=client_REPLACE_ME
KILN_WORKOS_JWKS_URL=                      # optional override
KILN_WORKOS_TEAM_CLAIM=kiln_team_id        # custom claim mapped in the WorkOS project
KILN_WORKOS_API_KEY=                       # optional, server-side API calls

# ── DynamoDB tables (names match CDK stack outputs) ──────────────────────────
KILN_TEAM_CONFIG_TABLE=kiln-team-config
KILN_PR_LEDGER_TABLE=kiln-pr-ledger
KILN_AUDIT_LOG_TABLE=kiln-audit-log
KILN_CHANGELOG_CACHE_TABLE=kiln-changelog-cache
KILN_RATE_LIMITER_TABLE=kiln-rate-limiter
KILN_GITHUB_TOKEN_CACHE_TABLE=kiln-github-token-cache

# ── SQS ──────────────────────────────────────────────────────────────────────
# REQUIRED: replace account id with your kiln sub-account.
KILN_UPGRADE_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/kiln-upgrade-queue.fifo

# ── GitHub App (secret is in Secrets Manager; ARN referenced here) ───────────
# REQUIRED: create the App, paste the id here, put the PEM in Secrets Manager.
KILN_GITHUB_APP_ID=0
KILN_GITHUB_APP_SECRET_ARN=arn:aws:secretsmanager:us-west-2:000000000000:secret:kiln/github-app-private-key-XXXXXX

# ── Bedrock ──────────────────────────────────────────────────────────────────
KILN_BEDROCK_REGION=us-west-2              # inference-profile region
KILN_BEDROCK_CLASSIFIER_MODEL=anthropic.claude-haiku-4-5
KILN_BEDROCK_SYNTHESIZER_MODEL=anthropic.claude-sonnet-4-6
KILN_BEDROCK_SYNTHESIZER_ESCALATION_MODEL=anthropic.claude-opus-4-6

# ── External call timeouts (ms) — explicit everywhere ────────────────────────
KILN_NPM_TIMEOUT_MS=5000
KILN_CHANGELOG_TIMEOUT_MS=10000
KILN_GITHUB_TIMEOUT_MS=15000
KILN_BEDROCK_TIMEOUT_MS=30000
KILN_SECRETS_TIMEOUT_MS=5000

# ── GitHub rate limiter (shared DDB token bucket) ────────────────────────────
KILN_GITHUB_RATE_CAPACITY=4500             # matches App rate budget /hour
KILN_GITHUB_RATE_REFILL_PER_SEC=1.25       # ~4500/hour

# ── Poller cadence (minutes) — must match EventBridge rule in CDK ────────────
KILN_POLLER_INTERVAL_MINUTES=15

# ── Grafana Cloud telemetry (Tempo traces + Mimir metrics + Loki logs) ───────
# Telemetry is OPT-IN. Kiln runs fine without it (CloudWatch remains the log
# destination via stderr), but most production deployments wire this up.
# The OTLP basic_auth credential lives in Secrets Manager — the handler
# fetches it at cold start so it never touches Lambda env.
# See docs/grafana-cloud-setup.md for the Grafana Cloud setup walkthrough.
KILN_TELEMETRY_ENABLED=false
OTEL_SERVICE_NAME=kiln
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-west-0.grafana.net/otlp
KILN_GRAFANA_CLOUD_OTLP_SECRET_ARN=arn:aws:secretsmanager:us-west-2:000000000000:secret:kiln/grafana-cloud/otlp-auth-XXXXXX
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev,service.version=0.1.0
OTEL_METRIC_EXPORT_INTERVAL=60000

# ── Notifications (optional) ─────────────────────────────────────────────────
KILN_SLACK_WEBHOOK_URL=
KILN_LINEAR_API_KEY=
