# Kiln environment variables
# Copy this file to .env and populate before running locally or in CI.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-west-2

# ── Okta OIDC (API Gateway JWT authorizer) ────────────────────────────────────
KILN_OKTA_ISSUER=https://your-org.okta.com/oauth2/default
KILN_OKTA_AUDIENCE=api://kiln

# ── DynamoDB table names (defaults match CDK stack) ───────────────────────────
KILN_TEAM_CONFIG_TABLE=kiln-team-config
KILN_PR_LEDGER_TABLE=kiln-pr-ledger
KILN_AUDIT_LOG_TABLE=kiln-audit-log
KILN_CHANGELOG_CACHE_TABLE=kiln-changelog-cache
KILN_RATE_LIMITER_TABLE=kiln-rate-limiter

# ── SQS ───────────────────────────────────────────────────────────────────────
KILN_UPGRADE_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/kiln-upgrade-queue.fifo
KILN_AUDIT_DLQ_URL=https://sqs.us-west-2.amazonaws.com/123456789012/kiln-audit-dlq

# ── GitHub App ────────────────────────────────────────────────────────────────
KILN_GITHUB_APP_ID=123456
KILN_GITHUB_APP_SECRET_ARN=arn:aws:secretsmanager:us-west-2:123456789012:secret:kiln/github-app-private-key-XXXXXX
KILN_GITHUB_INSTALLATION_ID=12345678
