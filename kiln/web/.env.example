# ─── Next.js / Auth ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# ─── Okta OIDC ────────────────────────────────────────────────────────────────
# Okta application client ID (public)
OKTA_CLIENT_ID=0oa1234567890abcdef
# Okta application client secret (private — never commit)
OKTA_CLIENT_SECRET=secret
# Okta org issuer URL (e.g. https://acme.okta.com/oauth2/default)
OKTA_ISSUER=https://acme.okta.com/oauth2/default

# ─── Kiln API ─────────────────────────────────────────────────────────────────
# URL of the Kiln backend API (eng-backend service)
NEXT_PUBLIC_KILN_API_URL=http://localhost:3001
# Internal API key for server-to-server calls (never exposed to browser)
KILN_API_KEY=internal-api-key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
