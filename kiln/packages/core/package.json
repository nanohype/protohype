{
  "name": "@kiln/core",
  "version": "0.1.0",
  "description": "Kiln core — dependency upgrade automation engine",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
