    "semver": "^7.7.4",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^4.1.4",
    "aws-sdk-client-mock": "^4.1.0",
    "msw": "^2.13.3",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
