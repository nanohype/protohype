{
  "name": "kiln",
  "version": "0.1.0",
  "description": "Dependency-upgrade automation — reads the changelog, identifies breaking changes, patches the call sites, opens the PR",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p infra/tsconfig.infra.json",
    "lint": "eslint src infra tests",
    "format": "prettier --check \"src/**/*.ts\" \"infra/**/*.ts\" \"tests/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"infra/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:evals": "KILN_RUN_EVALS=1 vitest run tests/evals",
    "test:watch": "vitest",
    "local": "tsx watch src/local.ts",
    "cdk": "cdk --app \"tsx infra/bin/kiln.ts\"",
    "cdk:synth": "npm run cdk -- synth",
    "cdk:diff": "npm run cdk -- diff",
    "cdk:deploy": "npm run cdk -- deploy --require-approval never",
    "seed": "bash scripts/seed-secrets.sh",
    "seed:staging": "bash scripts/seed-secrets.sh --env staging",
    "seed:production": "bash scripts/seed-secrets.sh --env production",
    "seed:staging:dry": "bash scripts/seed-secrets.sh --env staging --dry-run",
    "seed:production:dry": "bash scripts/seed-secrets.sh --env production --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@hono/aws-lambda": "^3.0.0",
    "@hono/node-server": "^1.19.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.0",
    "@opentelemetry/api": "^1.10.0",
    "@opentelemetry/api-logs": "^0.210.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.210.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.210.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.210.0",
    "@opentelemetry/resources": "^2.3.0",
    "@opentelemetry/sdk-logs": "^0.210.0",
    "@opentelemetry/sdk-metrics": "^2.3.0",
    "@opentelemetry/sdk-node": "^0.210.0",
    "@opentelemetry/semantic-conventions": "^1.32.0",
    "@slack/web-api": "^7.10.0",
    "@workos-inc/node": "^8.4.0",
    "hono": "^4.9.0",
    "jose": "^5.10.0",
    "semver": "^7.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "aws-cdk": "^2.1118.0",
    "aws-cdk-lib": "^2.250.0",
    "aws-sdk-client-mock": "^4.1.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "testcontainers": "^10.27.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
