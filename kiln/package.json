{
  "name": "kiln",
  "version": "0.1.0",
  "description": "Dependency-upgrade automation — reads the changelog, identifies breaking changes, patches the call sites, opens the PR",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs": "echo 'kiln: no generated API docs in v1 (all types documented inline)'"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "semver": "^7.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
