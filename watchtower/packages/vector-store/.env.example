# ── Vector Store Configuration ──────────────────────────────────────
#
# Copy this file to .env and fill in the values for your chosen provider.

# Default vector provider (memory, pgvector, qdrant, pinecone)
VECTOR_PROVIDER=pgvector

# ── pgvector ───────────────────────────────────────────────────────
# PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/vectors
# PGVECTOR_TABLE_NAME=embeddings
# PGVECTOR_DIMENSIONS=1536

# ── Qdrant ─────────────────────────────────────────────────────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=embeddings

# ── Pinecone ───────────────────────────────────────────────────────
# PINECONE_API_KEY=
# PINECONE_INDEX=embeddings
# PINECONE_NAMESPACE=default
