# ── Notion ───────────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations

# NOTION_TOKEN=

# ── Confluence ──────────────────────────────────────────────────────
# Atlassian API token + email for basic auth

# CONFLUENCE_EMAIL=
# CONFLUENCE_TOKEN=
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net

# ── Google Docs ─────────────────────────────────────────────────────
# OAuth2 bearer token for Google Docs API

# GOOGLE_DOCS_TOKEN=

# ── Coda ────────────────────────────────────────────────────────────
# API token from https://coda.io/account

# CODA_TOKEN=

# ── General ─────────────────────────────────────────────────────────

# LOG_LEVEL=info
