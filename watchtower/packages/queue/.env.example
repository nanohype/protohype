# ── BullMQ (Redis) ───────────────────────────────────────────────────

# Redis host for the BullMQ provider
# REDIS_HOST=127.0.0.1

# Redis port for the BullMQ provider
# REDIS_PORT=6379

# Queue name (defaults to the project name placeholder)
# QUEUE_NAME=my-queue

# ── SQS ──────────────────────────────────────────────────────────────

# Full SQS queue URL
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/my-queue

# AWS region for the SQS provider
# AWS_REGION=us-east-1
