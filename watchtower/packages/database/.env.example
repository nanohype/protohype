# ── Required ─────────────────────────────────────────────────────────

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── Optional ─────────────────────────────────────────────────────────

# Explicit driver override (postgres, sqlite, turso)
# Auto-detected from DATABASE_URL scheme when omitted
# DB_DRIVER=postgres

# ── Turso / libSQL ───────────────────────────────────────────────────

# Auth token for Turso cloud databases
# TURSO_AUTH_TOKEN=

# Sync URL for embedded replicas (local + remote sync)
# TURSO_SYNC_URL=
