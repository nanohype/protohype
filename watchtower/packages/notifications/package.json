{
  "name": "watchtower-notifications",
  "version": "0.1.0",
  "description": "Notifications for watchtower alerts",
  "type": "module",
  "main": "dist/notifications/index.js",
  "types": "dist/notifications/index.d.ts",
  "exports": {
    ".": "./dist/notifications/index.js",
    "./channels": "./dist/notifications/channels/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/notifications/index.ts",
    "start": "node dist/notifications/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "resend": "^4.0.0",
    "@sendgrid/mail": "^8.1.0",
    "twilio": "^5.0.0",
    "web-push": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "@types/web-push": "^3.6.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
