{
  "name": "watchtower-evals",
  "version": "0.1.0",
  "description": "Eval suites for watchtower classifier and memo drafter",
  "type": "module",
  "scripts": {
    "eval": "tsx bin/run-evals.ts",
    "eval:ci": "tsx bin/run-evals.ts --reporter json",
    "build": "tsc",
    "lint": "eslint src/ bin/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "openai": "^4.85.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
