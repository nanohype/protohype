{
  "name": "watchtower",
  "version": "0.1.0",
  "description": "Regulatory change radar",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:packages": "for pkg in packages/*/; do (cd \"$pkg\" && npm run lint) || exit 1; done",
    "lint:infra": "cd infra && npm run lint",
    "lint:all": "npm run lint && npm run lint:packages && npm run lint:infra",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:packages": "for pkg in packages/*/; do (cd \"$pkg\" && npm test) || exit 1; done",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "audit:prod": "npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@hono/node-server": "^1.13.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.60.0",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.7.0",
    "pg": "^8.13.0",
    "watchtower-knowledge-base": "file:./packages/knowledge-base",
    "watchtower-notifications": "file:./packages/notifications",
    "watchtower-observability": "file:./packages/observability",
    "watchtower-pipeline": "file:./packages/pipeline",
    "watchtower-vector-store": "file:./packages/vector-store",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0",
    "watchtower-evals": "file:./packages/evals"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "uuid": "^14.0.0"
  }
}
