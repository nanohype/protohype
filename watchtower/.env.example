# ── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
HEALTH_PORT=9090
SHUTDOWN_TIMEOUT_MS=30000

# ── AWS ─────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
# BEDROCK_REGION=us-west-2  # falls back to AWS_REGION when unset

# ── DynamoDB tables (names come from the CDK stack outputs) ─────────
CLIENTS_TABLE=watchtower-clients-staging
DEDUP_TABLE=watchtower-dedup-staging
MEMOS_TABLE=watchtower-memos-staging
AUDIT_TABLE=watchtower-audit-staging

# ── S3 ──────────────────────────────────────────────────────────────
AUDIT_BUCKET=watchtower-audit-staging-123456789012

# ── SQS queues ──────────────────────────────────────────────────────
CRAWL_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/watchtower-crawl-staging
CLASSIFY_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/watchtower-classify-staging
PUBLISH_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/watchtower-publish-staging
AUDIT_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/watchtower-audit-staging.fifo

# ── SQS consumer tuning ─────────────────────────────────────────────
CRAWL_CONCURRENCY=2
CLASSIFY_CONCURRENCY=5
PUBLISH_CONCURRENCY=2
AUDIT_CONCURRENCY=5
CONSUMER_POLL_INTERVAL_MS=1000

# ── pgvector corpus ─────────────────────────────────────────────────
CORPUS_HOST=localhost
CORPUS_PORT=5432
CORPUS_DATABASE=watchtower_staging
# In prod these come from Secrets Manager via ecs.Secret.fromSecretsManager.
CORPUS_USER=postgres
CORPUS_PASSWORD=changeme

# ── KMS envelope key (memos encryption) ─────────────────────────────
ENVELOPE_KMS_KEY_ID=arn:aws:kms:us-west-2:123456789012:key/00000000-0000-0000-0000-000000000000

# ── Bedrock ─────────────────────────────────────────────────────────
CLASSIFIER_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
MEMO_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_TIMEOUT_MS=30000

# ── Classifier thresholds (0–100) ───────────────────────────────────
APPLICABILITY_AUTO_ALERT_THRESHOLD=80
APPLICABILITY_REVIEW_THRESHOLD=50

# ── OAuth (Notion / Confluence service integrations) ────────────────
# In prod these are injected from Secrets Manager.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
CONFLUENCE_OAUTH_CLIENT_ID=
CONFLUENCE_OAUTH_CLIENT_SECRET=

# ── Notifications ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=watchtower@example.com

# ── Security (HMAC for signed URLs, ≥32 bytes) ──────────────────────
STATE_SIGNING_SECRET=replace-me-with-a-real-random-64-character-secret-value
